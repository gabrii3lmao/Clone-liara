---
import Layout from "../layouts/Layout.astro";
import TheHero from "../components/TheHero.astro";
import Card from "../components/Card.astro";
---

<Layout>
  <TheHero
    title="Laboratório de Inteligência Artificial, Robótica e Automação"
  />

  <div
    class="flex flex-col px-4 sm:px-8 md:px-16 lg:px-24 py-8 md:py-16 max-w-5xl mx-auto justify-center"
  >
    <h1
      class="text-2xl md:text-3xl font-bold text-primary-blue mb-4 text-center md:text-left"
    >
      Bem-vindo ao LIARA
    </h1>

    <p
      class="text-base md:text-lg text-gray-700 leading-relaxed text-justify md:text-left"
    >
      O Laboratório de Inteligência Artificial, Robótica e Automação (LIARA) é
      um centro de pesquisa dedicado ao desenvolvimento de soluções inovadoras
      nas áreas de inteligência artificial, robótica e sistemas de automação.
      Nosso objetivo é promover a excelência em pesquisa, desenvolvimento
      tecnológico e formação de recursos humanos qualificados.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-6 py-10">
    <Card
      title="Inteligência Artificial"
      description="Pesquisa e desenvolvimento em aprendizado de máquina, visão computacional e processamento de linguagem natural."
    />
    <Card
      title="Robótica"
      description="Desenvolvimento de sistemas robóticos autônomos e semi-autônomos para aplicações diversas."
    />
    <Card
      title="Automação"
      description="Soluções em automação industrial e residencial
    com foco em eficiência e inovação."
    />
  </div>
</Layout>
