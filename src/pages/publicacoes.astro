---
import Layout from "../layouts/Layout.astro";
import TheHero from "../components/TheHero.astro";
import { getCollection } from "astro:content";

export const prerender = true;

const posts = await getCollection("posts");
---

<Layout>
  <TheHero
    title="Publicações Científicas"
    subtitle="Trabalhos publicados pelos pesquisadores do LIARA"
  />

  <div class="flex flex-col items-center justify-center py-10">
    {
      posts.map((post) => (
        <div class="w-full max-w-3xl bg-white rounded-lg shadow-md p-6 mb-6">
          <h2 class="text-xl font-bold text-primary-blue mb-2">
            {post.data.title}
          </h2>
          <p class="text-gray-700 mb-4">{post.data.description}</p>
          <a
            href={`/publicacoes/${post.id}`}
            target="_blank"
            class="text-primary-blue hover:underline"
          >
            Ler publicação
          </a>
        </div>
      ))
    }
  </div>
</Layout>
