---
const { title, description } = Astro.props;
---

<div
  class="bg-white rounded-lg border border-gray-200 shadow-md p-6 md:p-8 w-full max-w-sm
            hover:shadow-xl hover:-translate-y-1.5
            transition-all duration-300 ease-out"
>
  <h2 class="text-lg md:text-xl font-bold text-primary-blue mb-2">{title}</h2>
  <p class="text-sm md:text-base text-dark-navy">{description}</p>
</div>
