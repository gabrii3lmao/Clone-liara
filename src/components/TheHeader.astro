---
const pages = [
  { title: "Home", href: "" },
  { title: "Projetos", href: "projetos" },
  { title: "Publicações", href: "publicacoes" },
  { title: "Membros", href: "membros" },
  { title: "Fotos", href: "fotos" },
];

// Pega o base URL (ex: "/Clone-liara") e garante que não termine com barra para não duplicar
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

// Pega o caminho atual da URL (ex: "/Clone-liara/" ou "/Clone-liara/projetos")
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-dark-navy shadow-blue-950 py-5 px-6">
  <nav class="flex items-center justify-between">
    <img
      src={`${baseUrl}/logo.png`}
      alt="LIARA"
      width="8%"
      class="object-contain ml-30"
    />
    <ul class="flex space-x-15 px-20">
      {
        pages.map((page) => {
          // 1. Montamos o caminho completo que o link terá no navegador
          const fullLinkPath =
            page.href === "" ? `${baseUrl}/` : `${baseUrl}/${page.href}`;

          // 2. Limpamos barras duplicadas no final para a comparação ser cirúrgica
          const normalizedCurrent = currentPath.replace(/\/$/, "");
          const normalizedLink = fullLinkPath.replace(/\/$/, "");

          // 3. A mágica do active: se os caminhos forem iguais, ou se for uma sub-rota (ex: /projetos/1)
          const isActive =
            normalizedCurrent === normalizedLink ||
            (page.href !== "" &&
              normalizedCurrent.startsWith(normalizedLink + "/"));

          return (
            <li>
              <a
                href={fullLinkPath}
                class={`text-[1rem] font-semibold transition-all duration-200 cursor-pointer pb-1
                  ${
                    isActive
                      ? "text-blue-400 border-b-3 border-blue-500"
                      : "text-white hover:text-blue-400 hover:border-b-3 hover:border-blue-500"
                  }`}
              >
                {page.title}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
