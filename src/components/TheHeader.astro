---
const pages = [
  { title: "Home", href: "" },
  { title: "Projetos", href: "projetos" },
  { title: "Publicações", href: "publicacoes" },
  { title: "Membros", href: "membros" },
  { title: "Fotos", href: "fotos" },
];

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full bg-dark-navy shadow-blue-950 py-4 px-4 md:px-8"
>
  <nav
    class="flex flex-col md:flex-row items-center justify-between max-w-7xl mx-auto gap-4 md:gap-0"
  >
    <img
      src={`${baseUrl}/logo.png`}
      alt="LIARA"
      class="object-contain w-16 sm:w-20 md:w-24"
    />

    <ul
      class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 md:gap-x-8 w-full md:w-auto"
    >
      {
        pages.map((page) => {
          const fullLinkPath =
            page.href === "" ? `${baseUrl}/` : `${baseUrl}/${page.href}`;
          const normalizedCurrent = currentPath.replace(/\/$/, "");
          const normalizedLink = fullLinkPath.replace(/\/$/, "");

          const isActive =
            normalizedCurrent === normalizedLink ||
            (page.href !== "" &&
              normalizedCurrent.startsWith(normalizedLink + "/"));

          return (
            <li>
              <a
                href={fullLinkPath}
                class={`text-sm md:text-[1rem] font-semibold transition-all duration-200 cursor-pointer pb-1 whitespace-nowrap
                  ${
                    isActive
                      ? "text-blue-400 border-b-2 md:border-b-3 border-blue-500"
                      : "text-white hover:text-blue-400 hover:border-b-2 md:hover:border-b-3 hover:border-blue-500"
                  }`}
              >
                {page.title}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
